# Copy this file to "local.properties" (already .gitignore'd - never commit the real one) and
# fill in your Maven repository's coordinates to enable `./gradlew publish`.
#
# Works with any Maven-compatible repository (GitHub Packages, Nexus, Artifactory, ...):
#   - GitHub Packages: publish.repoUrl = https://maven.pkg.github.com/<owner>/<repo>
#                       publish.repoUsername = your GitHub username
#                       publish.repoPassword = a PAT with the write:packages scope
#   - Nexus/Artifactory: publish.repoUrl = your repository's deploy URL,
#                        publish.repoUsername / publish.repoPassword = your deploy credentials
#
# publish.allowInsecureProtocol only needs to be true if publish.repoUrl is a plain http:// URL
# (e.g. an internal Nexus/Artifactory reachable only on a private network without TLS) - Gradle
# otherwise refuses to publish over http:// as a safety guard rail. Leave it false/unset for any
# https:// repository.

publish.repoUrl=
publish.repoUsername=
publish.repoPassword=
publish.allowInsecureProtocol=false
